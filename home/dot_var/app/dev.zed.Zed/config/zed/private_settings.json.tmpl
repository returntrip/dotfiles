  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "profiles": {
    },
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "session": {
    "restore_unsaved_buffers": true,
  },
  "autosave": "on_focus_change",
  "ssh_connections": [
    {
      "host": "archdemon.figura.io",
      "username": "returntrip",
      "args": [],
      "projects": [
        {
          "paths": ["/home/returntrip"],
        },
        {
          "paths": ["/home/ubuntu"],
        },
      ],
    },
    {
      "host": "se-container01",
      "args": [],
      "projects": [
        {
          "paths": ["/home/ubuntu"],
        },
        {
          "paths": ["/home/ubuntu/docker/./"],
